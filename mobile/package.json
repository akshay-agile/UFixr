{
  "name": "ufixr-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "prestart": "kill-port 8081",
    "preandroid": "kill-port 8081",
    "preios": "kill-port 8081",
    "preweb": "kill-port 8081",
    "start": "node scripts/start-expo.cjs",
    "start:reset": "kill-port 8081 && node scripts/start-expo.cjs --clear",
    "start:lan": "set EXPO_NETWORK_MODE=lan&& node scripts/start-expo.cjs",
    "start:tunnel": "set EXPO_NETWORK_MODE=tunnel&& node scripts/start-expo.cjs",
    "android": "node scripts/start-expo.cjs --android",
    "ios": "node scripts/start-expo.cjs --ios",
    "web": "node scripts/start-expo.cjs --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.2",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.25",
    "expo": "^54.0.0",
    "expo-camera": "~17.0.10",
    "expo-image-picker": "~17.0.8",
    "expo-location": "~19.0.7",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/react": "~19.1.10",
    "kill-port": "^2.0.1",
    "typescript": "~5.9.2"
  }
}
